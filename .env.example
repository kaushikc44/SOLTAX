# SolTax AU - required env vars. Copy to .env.local and fill in.

# === Supabase (required) ===
# ANON key is used by the browser + middleware for user auth.
# SERVICE key is server-only; bypasses RLS for system writes.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# === Solana RPC (required) ===
# Free tier works but rate-limits aggressively. Use Helius/Alchemy/QuickNode.
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# === Helius (optional, for enhanced tx parsing) ===
HELIUS_API_KEY=

# === Pricing (optional) ===
# Jupiter is used for current prices and has no key. CoinGecko is used for
# historical prices; pro key lifts rate limits but not required.
COINGECKO_API_KEY=

# === AI classification (optional) ===
ANTHROPIC_API_KEY=
GOOGLE_GENAI_API_KEY=

# === Paywall (required for Pro tier) ===
# Wallet that receives SOL payments. Must be a valid Solana address.
SOLANA_TREASURY_WALLET=
# One-time lifetime price in SOL. Change anytime; only affects future sign-ups.
SUBSCRIPTION_PRICE_SOL=0.1

# === Email reports (required for Pro email delivery) ===
# Sign up at https://resend.com — free tier, no card.
# FROM_EMAIL must be on a domain you've verified in Resend.
RESEND_API_KEY=
RESEND_FROM_EMAIL=SolTax AU <reports@your-domain.com>
